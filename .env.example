# Required: GitHub personal access token with repo scope
APP_GITHUB_TOKEN=ghp_your_token_here

# Required: Target repository in owner/repo format
APP_GITHUB_REPO=your-org/your-repo

# Optional: Branch to read/write files (default: main)
APP_GITHUB_BRANCH=main

# Optional: Root path in repo for initiative folders (default: initiatives/)
APP_FEATURES_BASE_PATH=initiatives/
